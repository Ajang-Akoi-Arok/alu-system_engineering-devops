#!/usr/bin/env bash
# This script configures Nginx to redirect /redirect_me with 301 status

# Update and install Nginx
apt-get update -y
apt-get install -y nginx -y

# Configure the redirect
# We need to add a location block for /redirect_me
sed -i '/server_name _;/a \\tlocation /redirect_me {\n\t\treturn 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;\n\t}' /etc/nginx/sites-available/default

# Test the configuration
nginx -t

# Restart Nginx without systemctl
service nginx restart
