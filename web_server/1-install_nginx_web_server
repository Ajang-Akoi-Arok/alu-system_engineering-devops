#!/usr/bin/env bash
# This script installs and configures Nginx web server with a custom homepage

# Update package lists
apt-get update -y

# Install Nginx
apt-get install -y nginx

# Create the index page with required content
echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# Ensure Nginx is configured to serve the correct page
# The default configuration already serves from /var/www/html
# We just need to make sure our content is there

# Restart Nginx without using systemctl
service nginx restart

# Make sure Nginx is running and listening on port 80
# The default configuration already listens on port 80
